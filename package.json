{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:full": "npm run build && npm run build:server",
    "start": "NODE_ENV=production npx tsx server.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
