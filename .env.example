# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public URL of the frontend (Vercel).
APP_URL="https://votre-app.vercel.app"

# PUBLIC_APP_URL (Railway) : URL publique du site pour les liens « suivi client » (/suivi/…).
# Ex. https://assurance-emprunteur.up.railway.app — pas de secret à configurer, le lien est unique par dossier.
PUBLIC_APP_URL="https://assurance-emprunteur.up.railway.app"

# VITE_API_URL: Backend URL (Railway). Set on Vercel so the frontend calls the API.
VITE_API_URL="https://votre-app.up.railway.app"

# Firebase — source de vérité Firestore (prod). Mêmes valeurs Vercel + Railway.
# Créez le projet avec assurance@leclubimmobilier.fr — voir docs/FIREBASE_CONFIGURATION_ASSURANCE.md
VITE_FIREBASE_API_KEY=""
FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
FIREBASE_PROJECT_ID=""
VITE_FIREBASE_APP_ID=""
FIREBASE_APP_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""
# Base Firestore nommée (laisser vide = default)
FIREBASE_DATABASE_ID=""
# Prod Railway : Firestore obligatoire (pas de db.json local)
DATA_STORE="firestore"
FIREBASE_REQUIRED="true"
# Dev local sans Firebase uniquement :
# USE_LOCAL_DB="true"
# Import unique data/db.json → Firestore :
# FIREBASE_IMPORT_LOCAL="true"

# Compte de service — export Drive auto à la soumission du formulaire (sans admin connecté).
# Guide : docs/CONFIGURATION_DRIVE_AUTO.md
# Recommandé sur Railway (évite les erreurs de guillemets) :
#   base64 -i ma-cle.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=""
# Alternative : JSON sur une seule ligne
GOOGLE_SERVICE_ACCOUNT_JSON=""

# GOOGLE_DRIVE_PARENT_FOLDER_ID: ID du dossier où créer les dossiers clients.
# Ouvrez le dossier dans Drive → URL : https://drive.google.com/drive/folders/XXXXXXXX
# Copiez XXXXXXXX (pas l'ID racine d'un Drive partagé type 0ALC2kSJGmwXjUk9PVA).
# Exemple « Dossiers Clients Assurance » :
GOOGLE_DRIVE_PARENT_FOLDER_ID="1KedZC85KypR6zpr5bZOLIh3eWAxiRz7u"

# Documentation Camille (fiches produits) — dossier « Documentation Camille » sur Drive
# Créer via GET /api/admin/camille-knowledge/setup-auto ou bouton admin, puis copier l'ID ici
CAMILLE_KNOWLEDGE_DRIVE_FOLDER_ID=""
CAMILLE_KNOWLEDGE_SYNC_ON_START="true"
CAMILLE_KNOWLEDGE_SYNC_ENABLED="true"
CAMILLE_KNOWLEDGE_SYNC_INTERVAL_MS="21600000"
# RAG Phase 2 — retrieval sémantique sur la doc Drive (embeddings Gemini)
CAMILLE_KNOWLEDGE_RAG_ENABLED="true"
CAMILLE_KNOWLEDGE_EMBED_MODEL="gemini-embedding-001"
CAMILLE_KNOWLEDGE_RAG_TOP_K="5"
CAMILLE_KNOWLEDGE_RAG_MAX_CHARS="9000"

# Camille Phase 3 — raisonnement multi-étapes (analyse → plan → rédaction → critique)
CAMILLE_REASONING_ENABLED="true"
CAMILLE_REASONING_MODEL="gemini-2.5-pro"
CAMILLE_REASONING_DRAFT_MODEL="gemini-2.5-pro"

# IA — réponses automatiques aux emails clients (nécessite GEMINI_API_KEY sur Railway)
AI_AUTO_REPLY_ENABLED="true"
# Délai minimum entre deux emails Camille au même client (évite les doublons)
CAMILLE_CLIENT_EMAIL_COOLDOWN_HOURS="4"

# OCR hybride (Gemini) : uniquement si le PDF n'a pas de texte natif (< 80 car.) ou fichier image
OCR_HYBRID_ENABLED="true"
OCR_HYBRID_MIN_TEXT_CHARS="80"
OCR_HYBRID_MODEL="gemini-2.5-flash"
OCR_HYBRID_MAX_BYTES="8000000"
# Au redémarrage Railway : réanalyse une fois par build (dossiers déjà en base)
OCR_HYBRID_BACKFILL_ON_START="true"
# Sync Gmail serveur + admin — intervalle en ms (défaut 2 min ; éco 5 min)
GMAIL_AUTOSYNC_INTERVAL_MS="120000"
# Mode éco Railway : sync 5 min + plage 8h–20h Paris (Telegram webhook reste actif)
RAILWAY_ECO_MODE="false"
GMAIL_AUTOSYNC_BUSINESS_HOURS_ONLY="false"
GMAIL_AUTOSYNC_BUSINESS_START_H="8"
GMAIL_AUTOSYNC_BUSINESS_END_H="20"
GMAIL_AUTOSYNC_ECO_INTERVAL_MS="300000"
# Autres leviers éco (Railway variables, sans code) :
# OCR_HYBRID_BACKFILL_ON_START="false"
# CAMILLE_KNOWLEDGE_SYNC_ON_START="false"
# OPS_DAILY_REPORT_AI_ENABLED="false"
# OPS_DAILY_REPORT_CHECK_MS="300000"
# SCHEDULER_INTERVAL_MS="300000"
# Délai avant envoi réponse Camille (~12–20 s par défaut)
CAMILLE_REPLY_DELAY_MS="12000"
CAMILLE_REPLY_DELAY_JITTER_MS="8000"
# Escalade : email remi@leclubimmobilier.fr + rappel si pas de reprise (heures)
AI_ESCALATION_EMAIL="remi@leclubimmobilier.fr"
AI_ESCALATION_COOLDOWN_HOURS="6"
AI_ESCALATION_REMINDER_HOURS="24"
# Notifications instantanées (optionnel, en plus de l'email Rémi)
# Slack : créer Incoming Webhook dans le workspace
AI_ESCALATION_SLACK_WEBHOOK_URL=""
# Discord : paramètres salon → intégrations → webhook
AI_ESCALATION_DISCORD_WEBHOOK_URL=""
# ntfy.sh : topic secret + app mobile ntfy (très réactif, gratuit)
AI_ESCALATION_NTFY_TOPIC=""
# Pause réponses auto Camille après un mail équipe au client (heures)
# Pause Camille après un mail équipe manuel (hors étude/accusé). 0 = pas de pause.
CAMILLE_PAUSE_AFTER_STAFF_HOURS="1"

# Telegram — alertes + réponse directe → Camille envoie le mail client
# 1) @BotFather → créer un bot → TELEGRAM_BOT_TOKEN
# 2) Ouvrir le bot, envoyer /start → récupérer chat_id → TELEGRAM_ALLOWED_CHAT_IDS
# 3) GET /api/telegram/setup-webhook?secret=VOTRE_TELEGRAM_SETUP_SECRET
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ALLOWED_CHAT_IDS=""
TELEGRAM_SETUP_SECRET=""
TELEGRAM_WEBHOOK_SECRET=""
# Alertes proactives Telegram (nouveau dossier, mail client) — true par défaut si bot configuré
TELEGRAM_NOTIFY_ENABLED="true"

# Rapport ops quotidien (Phase 1 — déterministe, sans LLM)
OPS_DAILY_REPORT_ENABLED="true"
OPS_DAILY_REPORT_HOUR="8"
OPS_DAILY_REPORT_EMAIL="remi@leclubimmobilier.fr"
OPS_DAILY_REPORT_TELEGRAM="true"
# Phase 2 : synthèse IA + audit des 3 dossiers les plus prioritaires (nécessite GEMINI_API_KEY déjà utilisée par Camille)
OPS_DAILY_REPORT_AI_ENABLED="true"
OPS_DAILY_REPORT_AI_TOP_DOSSIERS="3"

# GMAIL CONFIGURATION (Pour l'envoi et la lecture automatisée des emails)
GMAIL_USER="assurance@leclubimmobilier.fr"
GMAIL_APP_PASSWORD=""

# OAuth serveur (autonome 24/7 sans Super Admin Workspace)
# Utilise un refresh_token obtenu une seule fois.
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REFRESH_TOKEN=""

# SMTP CONFIGURATION (V1 email center + automations)
# If unset, the app runs in simulation mode (logs only).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="assurance@leclubimmobilier.fr"

# RGPD — registre des traitements + journal des consentements (Google Sheets)
# Créez une feuille avec 2 onglets (ou laissez l'app les créer) et partagez-la en éditeur avec
# le compte de service (client_email du JSON) ou assurance@leclubimmobilier.fr
# ID = segment dans https://docs.google.com/spreadsheets/d/XXXXXXXX/edit
RGPD_GOOGLE_SPREADSHEET_ID=""
RGPD_SHEET_REGISTER="Registre traitements"
RGPD_SHEET_CONSENTS="Journal consentements"
# Synchroniser le registre au démarrage Railway (true par défaut si ID renseigné)
RGPD_REGISTER_SYNC_ON_START="true"

# Scheduler
SCHEDULER_ENABLED="true"
SCHEDULER_INTERVAL_MS="60000"

