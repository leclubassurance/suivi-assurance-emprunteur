# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public URL of the frontend (Vercel).
APP_URL="https://votre-app.vercel.app"

# VITE_API_URL: Backend URL (Railway). Set on Vercel so the frontend calls the API.
VITE_API_URL="https://votre-app.up.railway.app"

# Firebase — set VITE_* on Vercel (frontend) and same values on Railway (backend sync)
VITE_FIREBASE_API_KEY=""
FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""

# Compte de service — export Drive auto à la soumission du formulaire (sans admin connecté).
# Guide : docs/CONFIGURATION_DRIVE_AUTO.md
# Recommandé sur Railway (évite les erreurs de guillemets) :
#   base64 -i ma-cle.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=""
# Alternative : JSON sur une seule ligne
GOOGLE_SERVICE_ACCOUNT_JSON=""

# GOOGLE_DRIVE_PARENT_FOLDER_ID: ID du dossier où créer les dossiers clients.
# Ouvrez le dossier dans Drive → URL : https://drive.google.com/drive/folders/XXXXXXXX
# Copiez XXXXXXXX (pas l'ID racine d'un Drive partagé type 0ALC2kSJGmwXjUk9PVA).
# Exemple « Dossiers Clients Assurance » :
GOOGLE_DRIVE_PARENT_FOLDER_ID="1KedZC85KypR6zpr5bZOLIh3eWAxiRz7u"

# IA — réponses automatiques aux emails clients (nécessite GEMINI_API_KEY sur Railway)
AI_AUTO_REPLY_ENABLED="true"

# GMAIL CONFIGURATION (Pour l'envoi et la lecture automatisée des emails)
GMAIL_USER="assurance@leclubimmobilier.fr"
GMAIL_APP_PASSWORD=""

# SMTP CONFIGURATION (V1 email center + automations)
# If unset, the app runs in simulation mode (logs only).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="assurance@leclubimmobilier.fr"

# Scheduler
SCHEDULER_ENABLED="true"
SCHEDULER_INTERVAL_MS="60000"

