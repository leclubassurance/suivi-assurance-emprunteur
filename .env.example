# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public URL of the frontend (Vercel).
APP_URL="https://votre-app.vercel.app"

# VITE_API_URL: Backend URL (Railway). Set on Vercel so the frontend calls the API.
VITE_API_URL="https://votre-app.up.railway.app"

# Firebase — source de vérité Firestore (prod). Mêmes valeurs Vercel + Railway.
# Créez le projet avec assurance@leclubimmobilier.fr — voir docs/FIREBASE_CONFIGURATION_ASSURANCE.md
VITE_FIREBASE_API_KEY=""
FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
FIREBASE_PROJECT_ID=""
VITE_FIREBASE_APP_ID=""
FIREBASE_APP_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""
# Base Firestore nommée (laisser vide = default)
FIREBASE_DATABASE_ID=""
# Prod Railway : Firestore obligatoire (pas de db.json local)
DATA_STORE="firestore"
FIREBASE_REQUIRED="true"
# Dev local sans Firebase uniquement :
# USE_LOCAL_DB="true"
# Import unique data/db.json → Firestore :
# FIREBASE_IMPORT_LOCAL="true"

# Compte de service — export Drive auto à la soumission du formulaire (sans admin connecté).
# Guide : docs/CONFIGURATION_DRIVE_AUTO.md
# Recommandé sur Railway (évite les erreurs de guillemets) :
#   base64 -i ma-cle.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=""
# Alternative : JSON sur une seule ligne
GOOGLE_SERVICE_ACCOUNT_JSON=""

# GOOGLE_DRIVE_PARENT_FOLDER_ID: ID du dossier où créer les dossiers clients.
# Ouvrez le dossier dans Drive → URL : https://drive.google.com/drive/folders/XXXXXXXX
# Copiez XXXXXXXX (pas l'ID racine d'un Drive partagé type 0ALC2kSJGmwXjUk9PVA).
# Exemple « Dossiers Clients Assurance » :
GOOGLE_DRIVE_PARENT_FOLDER_ID="1KedZC85KypR6zpr5bZOLIh3eWAxiRz7u"

# IA — réponses automatiques aux emails clients (nécessite GEMINI_API_KEY sur Railway)
AI_AUTO_REPLY_ENABLED="true"
# Accusé hors horaires lun–ven 9h–19h Paris : désactivé par défaut (Camille répond toujours).
# Mettre "true" en prod si vous voulez l’accusé « nous vous répondrons à l’ouverture » le soir/week-end.
AI_BUSINESS_HOURS_ENABLED="false"
# Escalade : email remi@leclubimmobilier.fr + rappel si pas de reprise (heures)
AI_ESCALATION_EMAIL="remi@leclubimmobilier.fr"
AI_ESCALATION_COOLDOWN_HOURS="6"
AI_ESCALATION_REMINDER_HOURS="24"
# Notifications instantanées (optionnel, en plus de l'email Rémi)
# Slack : créer Incoming Webhook dans le workspace
AI_ESCALATION_SLACK_WEBHOOK_URL=""
# Discord : paramètres salon → intégrations → webhook
AI_ESCALATION_DISCORD_WEBHOOK_URL=""
# ntfy.sh : topic secret + app mobile ntfy (très réactif, gratuit)
AI_ESCALATION_NTFY_TOPIC=""
# Pause réponses auto Camille après un mail équipe au client (heures)
CAMILLE_PAUSE_AFTER_STAFF_HOURS="48"

# Telegram — alertes + réponse directe → Camille envoie le mail client
# 1) @BotFather → créer un bot → TELEGRAM_BOT_TOKEN
# 2) Ouvrir le bot, envoyer /start → récupérer chat_id → TELEGRAM_ALLOWED_CHAT_IDS
# 3) GET /api/telegram/setup-webhook?secret=VOTRE_TELEGRAM_SETUP_SECRET
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ALLOWED_CHAT_IDS=""
TELEGRAM_SETUP_SECRET=""
TELEGRAM_WEBHOOK_SECRET=""
# Alertes proactives Telegram (nouveau dossier, mail client) — true par défaut si bot configuré
TELEGRAM_NOTIFY_ENABLED="true"

# GMAIL CONFIGURATION (Pour l'envoi et la lecture automatisée des emails)
GMAIL_USER="assurance@leclubimmobilier.fr"
GMAIL_APP_PASSWORD=""

# OAuth serveur (autonome 24/7 sans Super Admin Workspace)
# Utilise un refresh_token obtenu une seule fois.
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REFRESH_TOKEN=""

# SMTP CONFIGURATION (V1 email center + automations)
# If unset, the app runs in simulation mode (logs only).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="assurance@leclubimmobilier.fr"

# Scheduler
SCHEDULER_ENABLED="true"
SCHEDULER_INTERVAL_MS="60000"

