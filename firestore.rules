rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Accès client interdit — seul le serveur Railway (firebase-admin + compte de service) lit/écrit.
    // Le frontend n'utilise pas Firestore directement (auth Google + API Railway uniquement).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
